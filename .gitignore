# ==========================
# Ignore large folders / files
# ==========================
checkpoints/*
data/raw/*
data/processed/*
data/tokenized/*
*.pt
*.ckpt
*.bin
*.zip

# ==========================
# Exceptions for tracked placeholders
# ==========================
!checkpoints/README.md
!data/raw/README.md
!data/processed/README.md
!data/tokenized/README.md

# ==========================
# Track everything in code / runs
# ==========================
!src/
!runs/

# ==========================
# Skip editor and IDE folders
# ==========================
.vscode/
.git/

# ==========================
# Ignore Python bytecode
# ==========================
__pycache__/
*.pyc

